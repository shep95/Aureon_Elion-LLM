# =============================================================================
# SOLIA — Railway Variables
# =============================================================================
# 1. Railway project → + New → Database → PostgreSQL
# 2. Web service → Variables → Raw Editor → paste this entire block
# 3. Web service → Volumes → mount at /data
# 4. Replace secrets below from: cat data/railway-secrets.json (after first boot)
# =============================================================================

# --- Secrets (paste from data/railway-secrets.json) ---
AUREON_API_KEY=
AUREON_AUDIT_CHAIN_KEY=

# --- Database (Postgres service must be named Postgres, or change reference) ---
DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Persistence (volume on web service at /data — keeps secrets + audit logs) ---
AUREON_DATA_DIR=/data
AUREON_AUDIT_LOG_DIR=/data/audit

# --- Auto-learn (Zophiel taxonomy: 30 domains · 135 subs · 862 micro-topics) ---
AUREON_AUTO_LEARN=1
AUREON_AUTO_LEARN_ON_STARTUP=1
# 24/7 continuous learning on Railway (back-to-back batches, 5s pause between cycles).
AUREON_AUTO_LEARN_CONTINUOUS=1
AUREON_AUTO_LEARN_CYCLE_PAUSE_SEC=5
# Or use a fixed interval instead: AUREON_AUTO_LEARN_INTERVAL_SEC=3600
AUREON_AUTO_LEARN_EPOCHS=150
AUREON_AUTO_LEARN_MAX_GRADES=5
AUREON_AUTO_LEARN_BATCH_SIZE=50
AUREON_AUTO_LEARN_ALL=1
# Chunk full corpus across cycles (default 25 on Railway). 0 = all 862 per cycle.
AUREON_AUTO_LEARN_BATCH_SIZE=25
# Or set limits manually (0 or all = no cap on that tier):
# AUREON_AUTO_LEARN_DOMAIN_LIMIT=29
# AUREON_AUTO_LEARN_SUBDOMAIN_LIMIT=7
# AUREON_AUTO_LEARN_MICRO_LIMIT=3

# --- Activity logging (filter Railway logs: aureon.ai) ---
AUREON_ACTIVITY_LOG=1
AUREON_LOG_JSON=1
AUREON_LOG_LEVEL=INFO

# --- Security / nomad organism ---
AUREON_REPLAY_GUARD=1
AUREON_RATE_LIMIT_PER_MINUTE=30
AUREON_CHAOS_VEIL=1
AUREON_CHAOS_JITTER_MS=40
AUREON_ORGANISM_PULSE_MS=30000
AUREON_VAULT_BIND_FINGERPRINT=1

# --- Optional ---
# AUREON_CLIENT_ALLOWLIST=
# AUREON_REQUIREMENTS_SHA256=
AUREON_PRELOAD_OLIVETTI=0

# --- Self-inquiry (questions Aureon asks itself while learning) ---
AUREON_SELF_INQUIRY=1
AUREON_SELF_INQUIRY_QUESTIONS_PER_TARGET=2
AUREON_SELF_INQUIRY_MAX_PER_BATCH=25

# --- Meta-consciousness (identity / meta-cognition self-questions after each batch) ---
AUREON_META_CONSCIOUSNESS=1
AUREON_META_QUESTIONS_PER_CYCLE=2
AUREON_META_ON_STARTUP=1

# --- Prediction brain v7 — BPE + multi-head Q/K/V + code corpus training ---
AUREON_PREDICT_HEADS=4
AUREON_CODE_TRAIN_IN_PREDICT=1
AUREON_CODE_TRAIN_OVERSAMPLE=4
AUREON_CODE_RETRIEVAL_STRONG=0.42
AUREON_CODE_RETRIEVAL_MIN=0.28

# --- Prediction brain (attention LM: reasoning + long context + large vocab) ---
AUREON_PREDICT_BRAIN=1
AUREON_PREDICT_MAX_SEQ=1000000
AUREON_PREDICT_MAX_VOCAB=1000000
AUREON_PREDICT_CONTEXT_WORDS=1000000
AUREON_PREDICT_D_MODEL=128
AUREON_PREDICT_LAYERS=6
AUREON_PREDICT_D_FF=512
AUREON_PREDICT_EPOCHS=200
AUREON_PREDICT_REASON_TOKENS=24
AUREON_PREDICT_ANSWER_TOKENS=32
AUREON_PREDICT_DOC_LIMIT=1000000

# --- Phase 4–5: efficient inference (KV cache + speculative + sliding window) ---
AUREON_ATTENTION_WINDOW=512
AUREON_SPECULATIVE_DRAFT=4
AUREON_SPECULATIVE_DECODE=1
AUREON_QUANTIZE_INFER=1
AUREON_CHAT_REWARD=1
AUREON_REWARD_GOOD_THRESHOLD=0.55
AUREON_RAG_TOP_K=8
AUREON_RAG_MAX_FEATURES=8192
AUREON_PREDICT_CONTEXT_WORDS=400
AUREON_PREDICT_TRAIN_MAX_VOCAB=32000
AUREON_ABSTAIN_THRESHOLD=0.15
AUREON_PREDICT_TIMEOUT_SEC=8
AUREON_LEARNING_SNAPSHOT_TTL_SEC=30
AUREON_PREDICT_RATE_LIMIT_PER_MINUTE=10
AUREON_SESSION_MAX_TURNS=10

# --- Live web search (DuckDuckGo — no API key; set 1 to enable search+opinion routing) ---
AUREON_WEB_SEARCH_ENABLED=0
AUREON_SEARCH_TIMEOUT=8
AUREON_SEARCH_MAX_RESULTS=5

# --- Phase 5: multimodal inbox (drop files in data/raw/multimodal) ---
# image.jpg + image.jpg.txt caption sidecar, or audio.mp3 + transcript .txt

# --- GitHub learning sync (auto-push full corpus → learning-data branch) ---
# Pushes automatically: on startup, every interval, and after each auto-learn cycle.
# Create a fine-grained PAT with Contents: Read and write on all repos below.
AUREON_GITHUB_SYNC=1
AUREON_GITHUB_TOKEN=
AUREON_GITHUB_REPOS=houseofasher/SOLIA,ZorakCorp/Aureon-LLM,shep95/Aureon_Elion-LLM
AUREON_GITHUB_SYNC_BRANCH=learning-data
AUREON_GITHUB_SYNC_ON_CYCLE=1
AUREON_GITHUB_SYNC_ON_STARTUP=1
AUREON_GITHUB_SYNC_INTERVAL_SEC=3600
AUREON_GITHUB_SYNC_INCLUDE_TEXT=1
