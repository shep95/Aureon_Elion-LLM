"""Railway deployment env checklist — copy these into your web service variables."""

# Required for production
AUREON_API_KEY=generate-a-long-random-secret-here
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Recommended — stable audit chain across redeploys (64 hex chars = 32 bytes)
# python -c "import secrets; print(secrets.token_hex(32))"
AUREON_AUDIT_CHAIN_KEY=

# Automated learning (defaults ON when Railway + Postgres detected)
AUREON_AUTO_LEARN=1
AUREON_AUTO_LEARN_ON_STARTUP=1
AUREON_AUTO_LEARN_INTERVAL_SEC=3600
AUREON_AUTO_LEARN_MAX_GRADES=1
AUREON_AUTO_LEARN_EPOCHS=150

# Optional
AUREON_AUDIT_LOG_DIR=/tmp/aureon-audit
AUREON_PRELOAD_OLIVETTI=0
